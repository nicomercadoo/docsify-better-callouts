{
  "name": "docsify-better-callouts",
  "version": "0.1.0",
  "description": "A Docsify pluggin to impove (and customize) the default callouts.",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
      "build": "bun build src/main.js src/styles.css --outdir=dist --minify",
      "build:dist": "bun run build",
      "build:dev": "bun build src/main.js src/styles.css --outdir=demo --sourcemap",
      "build:watch": "bun build src/main.js src/styles.css --outdir=demo --sourcemap --watch",
      "demo": "bun run build:dev && bunx serve demo -l 8080"
  },
  "keywords": [
    "docsify",
    "docsify-plugin",
    "markdown",
    "callouts",
    "alerts",
    "blockquotes",
    "quotes"
  ],
  "author": "Nicolás Mercado",
  "license": "GPL-3.0",
  "devDependencies": {
  }
}
